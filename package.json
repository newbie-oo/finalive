{
  "name": "finalive-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:up": "docker compose up -d db",
    "db:logs": "docker compose logs -f db",
    "db:reset": "docker compose down -v db && docker compose up -d db",
    "mail:up": "docker compose up -d mailpit",
    "storage:up": "docker compose up -d minio",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "seed:media": "tsx --env-file=.env.local scripts/seed-real-media.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@react-email/components": "^0.0.36",
    "@react-pdf/renderer": "^4.1.6",
    "@tanstack/react-query": "^5.62.0",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@vidstack/react": "^1.12.13",
    "better-auth": "1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.36.4",
    "drizzle-zod": "0.5.1",
    "hls.js": "^1.6.16",
    "isomorphic-dompurify": "^3.10.0",
    "next": "16.2.4",
    "next-themes": "^0.4.4",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^3.0.4",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.5.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.5.0",
    "tiptap-markdown": "^0.9.0",
    "tus-js-client": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.0.0"
}
